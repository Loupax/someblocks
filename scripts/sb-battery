#!/bin/sh
bat=/sys/class/power_supply/BAT0
cap=$(cat "$bat/capacity")
status=$(cat "$bat/status")

if [ "$status" = "Charging" ]; then
    if   [ "$cap" -ge 90 ]; then icon="σΑ²³"
    elif [ "$cap" -ge 80 ]; then icon="σΑ²΄"
    elif [ "$cap" -ge 70 ]; then icon="σΑ²ä"
    elif [ "$cap" -ge 60 ]; then icon="σΑΔù"
    elif [ "$cap" -ge 50 ]; then icon="σΑ²â"
    elif [ "$cap" -ge 40 ]; then icon="σΑ²à"
    elif [ "$cap" -ge 30 ]; then icon="σΑ²΅"
    elif [ "$cap" -ge 20 ]; then icon="σΑ²Ü"
    else                         icon="σΑΔ€"
    fi
else
    if   [ "$cap" -ge 90 ]; then icon="σΑ¹Ι"
    elif [ "$cap" -ge 80 ]; then icon="σΑ²²"
    elif [ "$cap" -ge 70 ]; then icon="σΑ²¹"
    elif [ "$cap" -ge 60 ]; then icon="σΑ²Ä"
    elif [ "$cap" -ge 50 ]; then icon="σΑ¹Ω"
    elif [ "$cap" -ge 40 ]; then icon="σΑ¹Ψ"
    elif [ "$cap" -ge 30 ]; then icon="σΑ¹Ϋ"
    elif [ "$cap" -ge 20 ]; then icon="σΑ¹Φ"
    elif [ "$cap" -ge 10 ]; then icon="σΑ¹Μ"
    else                         icon="σΑ²é"
    fi
fi

printf "%s %3d%%" "$icon" "$cap"
